# Configuracion global de referencia
# Copia estos valores a apps/api/.env y apps/web/.env.local segun corresponda.

API_PORT=4000
# SQLite local para desarrollo (archivo se crea en apps/api/prisma/dev.db)
DATABASE_URL="file:./dev.db"
JWT_SECRET="super-secret-key"
JWT_EXPIRES_IN="7d"
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# Regla de verificacion para conductores (solo bypass local de desarrollo)
# false: conductor inicia pending y debe ser aprobado por admin
# true: conductor inicia approved automaticamente (solo dev)
AUTO_APPROVE_DRIVERS=false

# Google Maps (calculo de distancia por direcciones)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key


# Admin con permisos globales en rutas protegidas por Roles() para pruebas MVP.
# true: admin total | false: permisos estrictos por modulo.
ADMIN_SUPERUSER_MODE=true

