PORT=4000
NODE_ENV=development
# Habilita auto aprobacion de conductores SOLO en desarrollo local.
# En produccion debe permanecer en false.
AUTO_APPROVE_DRIVERS=false
ENABLE_DEV_DRIVER_AUTO_APPROVE_BYPASS=false

# SQLite local dentro del proyecto. Para pruebas rapidas usa este archivo.
DATABASE_URL="file:./dev_local.db"
JWT_SECRET="super-secret-key"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3000"

# Permite simular estados de pago para el pasajero dueno SOLO en desarrollo local.
# En produccion debe permanecer en false.
ALLOW_DEV_PAYMENT_SIMULATION=true

# Mercado Pago (sandbox/dev)
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""
MERCADOPAGO_WEBHOOK_SECRET=""
MERCADOPAGO_WEBHOOK_URL="http://localhost:4000/api/webhooks/mercadopago"
MERCADOPAGO_USE_SANDBOX=true

# Pago manual para pruebas operativas.
# Aqui deben ir SOLO datos comerciales del negocio, nunca datos personales.
MANUAL_PAYMENT_METHOD_LABEL="Transferencia bancaria empresarial"
MANUAL_PAYMENT_BENEFICIARY="VIAJA SEGURO"
MANUAL_PAYMENT_BUSINESS_ACCOUNT="CLABE_O_CUENTA_DEL_NEGOCIO"
MANUAL_PAYMENT_PROCESSOR_LABEL="VIAJA SEGURO"
MANUAL_PAYMENT_REFERENCE="VS-RESERVA"
MANUAL_PAYMENT_INSTRUCTIONS="Beneficiario comercial: VIAJA SEGURO\nMetodo o banco: Transferencia bancaria empresarial\nCuenta o CLABE del negocio: CLABE_O_CUENTA_DEL_NEGOCIO\nReferencia: VS-RESERVA\nSube tu comprobante para validacion manual del admin."



# Permite que admin autenticado pase cualquier regla de Roles() (modo MVP).
# true: admin con control total | false: respeta Roles exactos.
ADMIN_SUPERUSER_MODE=true

